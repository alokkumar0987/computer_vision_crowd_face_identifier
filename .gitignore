# --- Crowd Face Identifier Git Ignore ---

# Environment & Dependencies
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class

# Models (PTH is too large for GitHub > 100MB)
*.pth
*.pt
*.onnx

# Data & Privacy (CRITICAL: DO NOT COMMIT SUBJECT DATA)
datasets/backup/*
datasets/data/*
datasets/new_persons/*
datasets/face_features/*
!datasets/**/.gitkeep

# Application Artifacts
logs/
screenshots/
index.faiss

# IDE & OS
.idea/
.vscode/
.DS_Store
Thumbs.db
